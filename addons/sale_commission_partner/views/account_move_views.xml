<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_partner_commission" model="ir.ui.view">
        <field name="name">account.move.form.partner.commission</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_subtotal']" position="after">
                <field name="agent_id" optional="show"/>
                <field name="commission_amount" optional="show" widget="monetary"/>
                <field name="commission_locked" column_invisible="True"/>
                <field name="commission_plan_id" column_invisible="True"/>
                <field name="commission_rule_type" column_invisible="True"/>
                <field name="commission_rate" column_invisible="True"/>
                <field name="commission_base" column_invisible="True"/>
            </xpath>
        </field>
    </record>
</odoo>
