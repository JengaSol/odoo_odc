<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Hide My Commissions -->
    <record id="sale_commission.sale_commission_my_menu" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Hide Commissions (Sales Manager Report) -->
    <record id="sale_commission.sale_commission_plan_report_menu" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Hide Achievements Report -->
    <record id="sale_commission.sale_commission_achievement_report_menu" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    
    <!-- Hide Commissions in Reporting -->
    <record id="sale_commission.sale_commission_plan_report_menu_report" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <menuitem id="menu_sale_commission_refresh"
              name="Update Commissions"
              parent="sale_commission.menu_sale_commission"
              action="action_sale_commission_refresh_wizard"
              sequence="40"
              groups="sales_team.group_sale_manager"/>
</odoo>
