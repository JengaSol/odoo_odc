<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_commission_plan_achievement_parent_category" model="ir.ui.view">
        <field name="name">sale.commission.plan.achievement.parent.category</field>
        <field name="model">sale.commission.plan</field>
        <field name="inherit_id" ref="sale_commission.sale_commission_plan_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='achievement_ids']//field[@name='product_categ_id']" position="attributes">
                <attribute name="string">Parent Category</attribute>
                <attribute name="placeholder">All parent categories</attribute>
            </xpath>
        </field>
    </record>
</odoo>
